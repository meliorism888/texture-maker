{
  "name": "texture-maker",
  "version": "1.0.0",
  "description": "Browser-based procedural texture studio",
  "scripts": {
    "build": "esbuild app_new.jsx --bundle --minify --outfile=dist/app.js --platform=browser --loader:.jsx=jsx && cp style.css dist/style.css",
    "build:dev": "esbuild app_new.jsx --bundle --sourcemap --outfile=dist/app.js --platform=browser --loader:.jsx=jsx && cp style.css dist/style.css",
    "watch": "esbuild app_new.jsx --bundle --sourcemap --watch --outfile=dist/app.js --platform=browser --loader:.jsx=jsx",
    "serve": "npx serve dist"
  },
  "devDependencies": {
    "esbuild": "^0.25.0"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  }
}
